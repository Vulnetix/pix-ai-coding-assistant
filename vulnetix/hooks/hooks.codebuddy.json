{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/pre-commit-scan.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/manifest-edit-scan.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/post-install-scan.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/session-summary.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/stop-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CODEBUDDY_PROJECT_DIR/hooks/vuln-context-inject.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
