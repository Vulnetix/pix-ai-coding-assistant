{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/pre-commit-scan.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/manifest-edit-scan.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/post-install-scan.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/session-summary.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/stop-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "BeforePrompt": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/vuln-context-inject.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
